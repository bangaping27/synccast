{
    "manifest_version": 3,
    "name": "SyncCast — Watch Together",
    "version": "1.0.1",
    "description": "Watch YouTube together in perfect sync. Part of the Maja Ecosystem.",
    "permissions": [
        "tabs",
        "storage",
        "scripting",
        "declarativeContent",
        "offscreen",
        "alarms",
        "sidePanel",
        "downloads"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "host_permissions": [
        "*://*.youtube.com/*",
        "http://localhost:8080/*",
        "ws://localhost:8080/*"
    ],
    "background": {
        "service_worker": "src/background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "src/content/youtube.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "action": {
        "default_popup": "index.html",
        "default_title": "SyncCast",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "src/content/*"
            ],
            "matches": [
                "*://*.youtube.com/*"
            ]
        }
    ]
}